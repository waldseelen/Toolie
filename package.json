{
  "name": "toolie",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['.next','node_modules/.cache']) { try { fs.rmSync(p,{recursive:true,force:true}); console.log('removed',p); } catch(e){} }\"",
    "dev": "next dev --turbopack",
    "dev:clean": "npm run clean && next dev --turbopack",
    "dev:webpack": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "db:studio": "prisma studio",
    "db:translate:en": "tsx prisma/backfillDescriptionEn.ts",
    "db:taxonomy:backfill": "tsx prisma/backfillTaxonomy.ts",
    "check-links": "tsx scripts/linkChecker.ts",
    "db:seed-tags": "tsx prisma/seedTags.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/og": "^0.11.1",
    "minisearch": "^7.2.0",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "jsdom": "^29.0.2",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
